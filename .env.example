# ==================== SERVER ====================
PORT=8101
CONTEXT_PATH=/smart-query-service

# ==================== DATABASE ====================
DB_HOST=192.168.0.132
DB_PORT=5444
DB_NAME=digit
DB_USER=postgres
DB_PASSWORD=postgres

# Per-module schemas
DB_SCHEMA_MARKET=mrkt_kmc2_data
DB_SCHEMA_ENGINEERING=public

# Legacy (kept for backward compatibility)
DB_SCHEMA=mrkt_kmc2_data

DB_POOL_MAX=5

# ==================== NVIDIA NIM ====================
NVIDIA_API_URL=https://integrate.api.nvidia.com/v1/chat/completions
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_MODEL=meta/llama-3.3-70b-instruct
NVIDIA_TIMEOUT_MS=60000
NVIDIA_MAX_TOKENS=2048
NVIDIA_TEMPERATURE=0.0

# ==================== LOCAL OLLAMA (FALLBACK) ====================
OLLAMA_API_URL=http://localhost:11434/v1/chat/completions
OLLAMA_MODEL=sqlcoder:7b
OLLAMA_TIMEOUT_MS=180000
OLLAMA_MAX_TOKENS=2048
OLLAMA_TEMPERATURE=0.0
OLLAMA_ENABLED=false

# ==================== VALIDATION ====================
MAX_ROWS=5000
QUERY_TIMEOUT_SECONDS=30

# ==================== QUERY CACHE ====================
CACHE_ENABLED=true
CACHE_TTL_SECONDS=600
CACHE_MAX_KEYS=200

# ==================== AI EXPLAIN (SUMMARY) ====================
EXPLAIN_MAX_SAMPLE_ROWS=30
EXPLAIN_MAX_TOKENS=1024

# ==================== EMAIL (SCHEDULED REPORTS) ====================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=KMC Smart Query <noreply@kmc.gov.in>

# ==================== DASHBOARDS ====================
DASHBOARD_SCHEMA=mrkt_kmc2_data

# ==================== SCHEDULER ====================
# Set to true to enable cron-based scheduled report email delivery
SCHEDULER_ENABLED=false
